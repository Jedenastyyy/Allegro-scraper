{
  "manifest_version": 3,
  "name": "Allegro Scraper",
  "version": "1.0",
  "description": "Scrapuje dane z list produktów Allegro i eksportuje do XLSX",
  "permissions": ["activeTab", "scripting", "downloads", "storage", "tabs"],
  "host_permissions": [
    "*://allegro.pl/*",
    "*://api.github.com/*",
    "*://gist.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Allegro Scraper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://allegro.pl/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
